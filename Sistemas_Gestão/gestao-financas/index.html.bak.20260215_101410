        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');

            sidebar.classList.toggle('open');
            overlay.classList.toggle('hidden');

            // Bloquear scroll do body quando sidebar aberta
            document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
        }

        // DASHBOARD
        function renderDashboard() {
            const monthSelector = document.getElementById('month-selector').value;
            const currentMonth = monthSelector || new Date().toISOString().slice(0, 7);

            // Filtrar transações do mês atual
            const monthTrans = db.transactions.filter(t => t.date.startsWith(currentMonth));

            // Calcular totais
            const income = monthTrans.filter(t => t.type === 'income')
                .reduce((sum, t) => sum + t.amount, 0);
            const expense = monthTrans.filter(t => t.type === 'expense')
                .reduce((sum, t) => sum + t.amount, 0);
            const economy = income - expense;

            // Atualizar cards
            const economyElement = document.getElementById('dash-economy');
            economyElement.innerText = fmtMoney(economy);

            // Cor dinâmica para economia
            if (economy >= 0) {
                economyElement.classList.remove('text-red-600');
                economyElement.classList.add('text-gray-900');
            } else {
                economyElement.classList.remove('text-gray-900');
                economyElement.classList.add('text-red-600');
            }

            document.getElementById('dash-income').innerText = fmtMoney(income);
            document.getElementById('dash-expense').innerText = fmtMoney(expense);

            // Atualizar alerta de saldo negativo
            const balanceAlert = document.getElementById('balance-alert');
            balanceAlert.classList.toggle('hidden', economy >= 0);

            // Calcular e mostrar crescimento
            const prevMonth = getPreviousMonthData(currentMonth);
            const incomeGrowth = calculatePercentage(income, prevMonth.income);
            const expenseGrowth = calculatePercentage(expense, prevMonth.expense);

            document.getElementById('income-growth').innerText = `${incomeGrowth}%`;
            document.getElementById('expense-growth').innerText = `${expenseGrowth}%`;

            // Atualizar gráfico
            renderChart();

            // Atualizar top despesas
            renderTopExpenses(monthTrans);

            // Atualizar categorias do mês
            renderCategoryBalance(monthTrans);

            // Atualizar transações recentes
            renderRecentTransactions();
        }

        function getPreviousMonthData(currentMonth) {
            const [year, month] = currentMonth.split('-').map(Number);
            let prevYear = year;
            let prevMonth = month - 1;

            if (prevMonth === 0) {
                prevMonth = 12;
                prevYear--;
            }

            const prevMonthStr = `${prevYear}-${prevMonth.toString().padStart(2, '0')}`;
            const prevTrans = db.transactions.filter(t => t.date.startsWith(prevMonthStr));

            return {
                income: prevTrans.filter(t => t.type === 'income').reduce((a, b) => a + b.amount, 0),
                expense: prevTrans.filter(t => t.type === 'expense').reduce((a, b) => a + b.amount, 0)
            };
        }

        function renderChart() {
            const chartArea = document.getElementById('chart-area');
            const today = new Date();
            const dataChart = [];

            // Coletar dados dos últimos 7 dias
            for (let i = 6; i >= 0; i--) {
                const d = new Date();
                d.setDate(today.getDate() - i);
                const ds = d.toISOString().split('T')[0];
                const dayTrans = db.transactions.filter(t => t.date === ds);

                dataChart.push({
                    lbl: `${d.getDate()}/${d.getMonth() + 1}`,
                    inc: dayTrans.filter(t => t.type === 'income').reduce((a, b) => a + b.amount, 0),
                    exp: dayTrans.filter(t => t.type === 'expense').reduce((a, b) => a + b.amount, 0)
                });
            }

            const max = Math.max(...dataChart.map(d => Math.max(d.inc, d.exp))) || 100;

            let chartHTML = '';
            dataChart.forEach(d => {
                chartHTML += `
                <div class="bar-group">
                    <div class="bar-wrapper">
                        <div class="bar rounded-bar bg-green-500" 
                             style="height:${(d.inc / max) * 100}%"
                             data-value="${fmtMoney(d.inc)}"></div>
                        <div class="bar rounded-bar bg-red-500" 
                             style="height:${(d.exp / max) * 100}%"
                             data-value="${fmtMoney(d.exp)}"></div>
                    </div>
                    <div class="x-label">${d.lbl}</div>
                </div>`;
            });

            chartArea.innerHTML = chartHTML || '<p class="text-gray-400 text-sm">Sem dados para exibir</p>';
        }

        function renderTopExpenses(transactions) {
            const expenseMap = {};

            transactions.filter(t => t.type === 'expense').forEach(t => {
                const cat = db.categories.find(c => c.id === t.catId);
                const catName = cat ? cat.name : 'Geral';
                expenseMap[catName] = (expenseMap[catName] || 0) + t.amount;
            });

            const topExpenses = Object.entries(expenseMap)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 5);

            const container = document.getElementById('top-expenses');

            if (topExpenses.length === 0) {
                container.innerHTML = '<p class="text-gray-400 text-sm text-center">Sem despesas este mês</p>';
                return;
            }

            const maxExpense = topExpenses[0]?.[1] || 1;

            container.innerHTML = topExpenses.map(([name, value]) => `
                <div class="space-y-1">
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-medium text-gray-700">${name}</span>
                        <span class="text-sm font-bold text-red-600">${fmtMoney(value)}</span>
                    </div>
                    <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
                        <div class="bg-red-400 h-full transition-all duration-500" 
                             style="width: ${(value / maxExpense) * 100}%"></div>
                    </div>
                </div>
            `).join('');
        }

        function renderCategoryBalance(transactions) {
            const categoryMap = {};

            transactions.forEach(t => {
                const cat = db.categories.find(c => c.id === t.catId);
                const catName = cat ? cat.name : 'Geral';
                const catType = cat ? cat.type : t.type;

                if (!categoryMap[catName]) {
                    categoryMap[catName] = { income: 0, expense: 0, color: cat?.color || '#6B7280' };
                }

                if (t.type === 'income') {
                    categoryMap[catName].income += t.amount;
                } else {
                    categoryMap[catName].expense += t.amount;
                }
            });

            const container = document.getElementById('category-balance');
            const categories = Object.entries(categoryMap)
                .sort((a, b) => (b[1].income + b[1].expense) - (a[1].income + a[1].expense))
                .slice(0, 4);

            if (categories.length === 0) {
                container.innerHTML = '<p class="text-gray-400 text-sm text-center">Sem dados por categoria</p>';
                return;
            }

            container.innerHTML = categories.map(([name, data]) => {
                const net = data.income - data.expense;
                return `
                    <div class="flex items-center justify-between p-2 hover:bg-gray-50 rounded-lg">
                        <div class="flex items-center">
                            <div class="w-3 h-3 rounded-full mr-2" style="background:${data.color}"></div>
                            <span class="text-sm text-gray-700">${name}</span>
                        </div>
                        <span class="text-sm font-bold ${net >= 0 ? 'text-green-600' : 'text-red-600'}">
                            ${net >= 0 ? '+' : ''}${fmtMoney(net)}
                        </span>
                    </div>
                `;
            }).join('');
        }

        function renderRecentTransactions() {
            const container = document.getElementById('recent-transactions');
            const recent = db.transactions
                .sort((a, b) => new Date(b.date) - new Date(a.date))
                .slice(0, 5);

            if (recent.length === 0) {
                container.innerHTML = '<p class="text-gray-400 text-sm text-center">Nenhum lançamento recente</p>';
                return;
