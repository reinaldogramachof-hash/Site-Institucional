            container.innerHTML = recent.map(t => {
                const cat = db.categories.find(c => c.id === t.catId);
                return `
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg border border-gray-100">
                        <div class="flex items-center">
                            <div class="w-8 h-8 rounded-full ${t.type === 'income' ? 'bg-green-100' : 'bg-red-100'} flex items-center justify-center mr-3">
                                <i data-lucide="${t.type === 'income' ? 'arrow-down-right' : 'arrow-up-right'}" 
                                   class="w-4 h-4 ${t.type === 'income' ? 'text-green-600' : 'text-red-600'}"></i>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-800">${t.desc}</p>
                                <p class="text-xs text-gray-500">${fmtDate(t.date)} • ${cat?.name || 'Geral'}</p>
                            </div>
                        </div>
                        <span class="text-sm font-bold ${t.type === 'income' ? 'text-green-600' : 'text-red-600'}">
                            ${t.type === 'income' ? '+' : '-'}${fmtMoney(t.amount)}
                        </span>
                    </div>
                `;
            }).join('');

