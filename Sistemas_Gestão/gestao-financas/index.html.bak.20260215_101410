    <script>
        // ESTADO GLOBAL
        const DB_KEY = 'plena_financas_pro_v2';
        const defaultDB = {
            transactions: [],
            categories: [
                { id: '1', name: 'Salário', type: 'income', color: '#10B981' },
                { id: '2', name: 'Extra', type: 'income', color: '#3B82F6' },
                { id: '3', name: 'Aluguel', type: 'expense', color: '#EF4444' },
                { id: '4', name: 'Mercado', type: 'expense', color: '#F59E0B' },
                { id: '5', name: 'Lazer', type: 'expense', color: '#8B5CF6' },
                { id: '6', name: 'Saúde', type: 'expense', color: '#EC4899' },
                { id: '7', name: 'Transporte', type: 'expense', color: '#6366F1' },
                { id: '8', name: 'Educação', type: 'expense', color: '#14B8A6' }
            ],
            settings: {
                currency: 'R$',
                theme: 'light',
                autoBackup: true,
                termsAccepted: false,
                termsAcceptedAt: null
            },
            tutorial: {
                completedSteps: [],
                checklistState: {}
            }
        };

        let db = JSON.parse(localStorage.getItem(DB_KEY)) || defaultDB;

        // UTILITÁRIOS
        const save = () => {
            localStorage.setItem(DB_KEY, JSON.stringify(db));
            updateDataStatus();
        };

        const fmtMoney = (v) => {
            return v.toLocaleString('pt-BR', {
                style: 'currency',
                currency: 'BRL',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        };

        const fmtDate = (d) => {
            const date = new Date(d);
            return date.toLocaleDateString('pt-BR');
        };

        const fmtDateInput = (d) => {
            return new Date(d).toISOString().split('T')[0];
        };

        const getID = () => {
            return Date.now().toString(36) + Math.random().toString(36).substr(2, 5);
        };

        const calculatePercentage = (current, previous) => {
            if (previous === 0) return current > 0 ? 100 : 0;
            return ((current - previous) / previous * 100).toFixed(1);
        };

        // MANUAL & CHECKLIST LOGIC
        function updateTutorialProgress() {
            if (!db.tutorial) return;
            const totalSteps = 7;
            const completed = db.tutorial.completedSteps.length;
            const progress = (completed / totalSteps) * 100;
            
            const pb = document.getElementById('tutorial-progress');
            const pt = document.getElementById('tutorial-percent');
            
            if (pb) pb.style.width = `${progress}%`;
            if (pt) pt.textContent = `${Math.round(progress)}%`;

            // Update section buttons
            db.tutorial.completedSteps.forEach(stepId => {
                const btn = document.querySelector(`button[onclick="markSectionComplete('${stepId}')"]`);
                if (btn) {
                    btn.innerHTML = '<i data-lucide="check" class="w-4 h-4 mr-2"></i>Concluído';
                    btn.classList.remove('bg-blue-50', 'text-blue-600', 'bg-orange-50', 'text-orange-600', 'bg-green-50', 'text-green-600', 'bg-purple-50', 'text-purple-600', 'bg-yellow-50', 'text-yellow-600', 'bg-red-50', 'text-red-600', 'bg-gray-50', 'text-gray-600');
                    btn.classList.add('bg-green-100', 'text-green-700');
                }
            });
        }

        function markSectionComplete(sectionId) {
            if (!db.tutorial) db.tutorial = { completedSteps: [], checklistState: {} };
            if (!db.tutorial.completedSteps.includes(sectionId)) {
                db.tutorial.completedSteps.push(sectionId);
                save();
                updateTutorialProgress();
                showNotification('Etapa concluída!', 'success');
            }
        }

        const checklistData = [
            { id: 'chk_app', text: 'Instalar Aplicativo', sub: 'Acessar via ícone na tela inicial' },
            { id: 'chk_config', text: 'Dados e Moeda', sub: 'Moeda e tema configurados' },
            { id: 'chk_cat', text: 'Categorias', sub: 'Personalizar seus tipos de gastos' },
            { id: 'chk_trans', text: 'Primeiro Lançamento', sub: 'Registrar uma receita ou despesa' },
            { id: 'chk_dash', text: 'Analisar Dashboard', sub: 'Verificar saldo e economia do mês' },
            { id: 'chk_backup', text: 'Backup', sub: 'Cópia de segurança realizada' }
        ];

        function renderChecklist() {
            const container = document.getElementById('checklist-items');
            if (!container || !db.tutorial) return;

            container.innerHTML = checklistData.map(item => {
                const isDone = db.tutorial.checklistState[item.id];
                return `
                    <div onclick="toggleChecklistItem('${item.id}')" class="flex items-start gap-3 p-3 rounded-xl border border-gray-100 hover:border-plena-blue cursor-pointer transition-all ${isDone ? 'bg-gray-50 opacity-75' : 'bg-white shadow-sm'}">
                        <div class="w-6 h-6 rounded-full border-2 flex-shrink-0 flex items-center justify-center transition-all ${isDone ? 'bg-green-500 border-green-500 text-white' : 'border-gray-200'}">
                            ${isDone ? '<i data-lucide="check" class="w-4 h-4"></i>' : ''}
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-sm ${isDone ? 'text-gray-400 line-through' : 'text-gray-800'}">${item.text}</p>
                            <p class="text-xs text-gray-500">${item.sub}</p>
                        </div>
                    </div>
                `;
            }).join('');
            lucide.createIcons();
        }

        function toggleChecklistItem(id) {
